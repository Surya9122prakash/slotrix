{
  "name": "@slotrix/calendar-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepublish": "rm -rf ./dist && npm run build",
    "build": "vite build"
  },
  "main": "./dist/slotrix-calendar.umd.js",
  "module": "./dist/slotrix-calendar.es.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Surya9122prakash/slotrix.git"
  },
  "exports": {
    ".": {
      "import": "./dist/slotrix-calendar.es.js",
      "require": "./dist/slotrix-calendar.umd.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "tailwindcss": "^4.2.1"
  },
  "peerDependencies": {
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}